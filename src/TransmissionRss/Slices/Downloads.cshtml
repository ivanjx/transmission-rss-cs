@inherits RazorSlice<DownloadsModel>
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Downloaded torrents · Transmission RSS</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/app.css" />
</head>
<body>
    <header class="topbar">
        <a class="brand" href="/"><span class="mark">TR</span><strong>Transmission RSS</strong></a>
        <a href="/">Dashboard</a>
    </header>
    <main class="shell">
        @if (!string.IsNullOrWhiteSpace(Model.Notice))
        {
            <div class="notice">@Model.Notice</div>
        }
        <section class="hero">
            <div><p class="eyebrow">HISTORY</p><h1>Downloaded torrents</h1><p>Successful downloads are kept for deduplication. Removing one allows it to trigger again.</p></div>
        </section>

        <section class="panel">
            <div class="section-heading">
                <div><p class="eyebrow">RECENT</p><h2>Torrents sent to Transmission</h2></div>
                @if (Model.Torrents.Count > 0)
                {
                    <form method="post" action="/downloads/clear" onsubmit="return confirm('Clear all downloaded torrents? They may be downloaded again on the next poll.')">
                        <button class="button danger" type="submit"><svg class="icon" aria-hidden="true" viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6M10 11v5M14 11v5" /></svg>Clear all</button>
                    </form>
                }
            </div>
            @if (Model.Torrents.Count == 0)
            {
                <div class="empty"><strong>No downloaded torrents yet.</strong><p>Items appear here after Transmission accepts them.</p></div>
            }
            else
            {
                <div class="download-list">
                @foreach (var torrent in Model.Torrents)
                {
                    <div class="download">
                        <span class="download-main">
                            <strong>@torrent.Title</strong>
                            <small>@torrent.RuleName · @torrent.DownloadedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz") · @(torrent.AddPaused ? "Paused" : "Started")</small>
                            <small>Destination: @(string.IsNullOrWhiteSpace(torrent.DownloadDirectory) ? "Transmission default" : torrent.DownloadDirectory)</small>
                        </span>
                        <form method="post" action="/downloads/delete" onsubmit="return confirm('Delete this downloaded torrent? It may be downloaded again on the next poll.')">
                            <input name="ruleId" type="hidden" value="@torrent.RuleId" />
                            <input name="uniqueId" type="hidden" value="@torrent.UniqueId" />
                            <button class="icon-button" type="submit" aria-label="Delete @torrent.Title" title="Delete"><svg class="icon" aria-hidden="true" viewBox="0 0 24 24"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6M10 11v5M14 11v5" /></svg></button>
                        </form>
                    </div>
                }
                </div>
            }
        </section>
    </main>
</body>
</html>
